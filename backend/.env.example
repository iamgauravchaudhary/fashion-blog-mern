# Environment Configuration Template
# Copy this to .env and fill in your actual values

# ============================================
# DATABASE
# ============================================
MONGO_URI=mongodb://localhost:27017/fashion-vlog
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/fashion-vlog

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============================================
# AI SERVICES - TEXT GENERATION
# ============================================

# OpenRouter API (for outfit suggestions and chat)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API (optional, for outfit generation fallback)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# AI SERVICES - IMAGE GENERATION
# ============================================

# HuggingFace API (for FLUX.1-dev image generation)
# Get your token from: https://huggingface.co/settings/tokens
# Must have 'read' access permission
HF_API_KEY=your_huggingface_api_key_here

# ============================================
# SERVER
# ============================================
PORT=5000
NODE_ENV=development
# For production: NODE_ENV=production

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000
# For production:
# CORS_ORIGIN=https://yourdomain.com

# ============================================
# OPTIONAL: Email Configuration
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
